--// Session Tracker Hook
task.spawn(function()
    local TextSendingRE = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("TextSendingRE")
    if not TextSendingRE then
        local success, remote = pcall(function()
            return ReplicatedStorage:WaitForChild("Remotes", 60):WaitForChild("TextSendingRE", 60)
        end)
        if success then TextSendingRE = remote end
    end

    if TextSendingRE then
        TextSendingRE.OnClientEvent:Connect(function(text, color)
            if not text then return end

            local amount = tonumber(string.match(text, "Earn (%d+)"))
            if amount then
                if string.find(string.lower(text), "honor") then
                    sessionHonor = sessionHonor + amount
                elseif string.find(string.lower(text), "beli") or string.find(text, "$") then
                    sessionMoney = sessionMoney + amount
                end
            else
                if string.find(text, "Dropped") or string.find(text, "Found") then
                    if sessionItemCounts[text] then
                        sessionItemCounts[text] = sessionItemCounts[text] + 1
                    else
                        sessionItemCounts[text] = 1
                    end
                end
            end

            local itemListStr = ""
            for item, count in pairs(sessionItemCounts) do
                if count > 1 then
                    itemListStr = itemListStr .. "- " .. item .. " (" .. count .. ")\n"
                else
                    itemListStr = itemListStr .. "- " .. item .. "\n"
                end
            end
            if itemListStr == "" then itemListStr = "- None" end

            if SessionLabel then
                SessionLabel.Text = "Honor: " .. sessionHonor ..
                                    "\nMoney: " .. sessionMoney ..
                                    "\nItems Found:\n" .. itemListStr
            end
        end)
    end
end)

