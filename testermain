local function MobScannerLoop()
    while task.wait(5) do
        local newMobs = GetBossNames()
        local changed = false

        if #newMobs ~= #currentMobOptions then
            changed = true
        else
            for i = 1, #newMobs do
                if newMobs[i] ~= currentMobOptions[i] then
                    changed = true
                    break
                end
            end
        end

        if changed then
            currentMobOptions = newMobs
            if SelectiveDropdown then
                -- Save and restore callback to prevent unwanted triggers
                local saved = SelectiveDropdown.ValueChanged
                SelectiveDropdown.ValueChanged = nil
                SelectiveDropdown.Value = {}
                while #SelectiveDropdown.Options > 0 do
                    SelectiveDropdown:Remove(1)
                end
                for _, name in ipairs(currentMobOptions) do
                    SelectiveDropdown:Option(name)
                end
                SelectiveDropdown.ValueChanged = saved
            end
        end
    end
end

local function FightMobLoop(mob, runningFlag)
    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
    local mobHumanoid = mob:FindFirstChildOfClass("Humanoid")
    if not mobHRP or not mobHumanoid then return end

    if mobHRP.Parent then
        TweenTo(mobHRP.CFrame * CFrame.new(0, 0, 8))
        if not runningFlag() then return end
    end

    EquipToolByName(selectedFarmingTool)

    local Character = LocalPlayer.Character
    local combatObj = Character and Character:FindFirstChild("Combat", true)
    local Event = combatObj and combatObj:FindFirstChild("RemoteEvent")

    -- Wait a second for tool to properly equip if it wasn't ready
    if not Event then
        task.wait(1)
        Character = LocalPlayer.Character
        combatObj = Character and Character:FindFirstChild("Combat", true)
        Event = combatObj and combatObj:FindFirstChild("RemoteEvent")
    end

    if not Event then return end

    -- ROBUST MOB CHECK LOOP: Prevents crash when mob dies and game destroys its instances
    while runningFlag() do
        local mobAlive = false
        pcall(function()
            -- pcall will safely catch the error if mobHumanoid is destroyed by the game
            mobAlive = mobHumanoid.Parent and mobHumanoid.Health > 0
        end)

        if not mobAlive then break end

        local myChar = LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local myHum = myChar and myChar:FindFirstChildOfClass("Humanoid")

        if not myChar or not myHRP or not myHum or myHum.Health <= 0 then break end

        pcall(function() Event:FireServer("Combat", "Combo") end)

        pcall(function()
            if mobHRP and mobHRP.Parent then
                myHRP.CFrame = mobHRP.CFrame * CFrame.new(0, 0, 8)
            end
        end)

        task.wait(0.15)
    end

    task.wait(1)
end

--// Main Farm Loop
local function AutoFarmLoop()
    if farmLoopActive then return end
    farmLoopActive = true

    local ok, err = pcall(function()

    while isRunning or isSelectiveFarming do
        task.wait(0.5)
        if not isRunning and not isSelectiveFarming then break end

        local Character = LocalPlayer.Character
        local HRP = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")

        if not Character or not HRP or not Humanoid or Humanoid.Health <= 0 then
            Character = LocalPlayer.CharacterAdded:Wait()
            HRP = Character:WaitForChild("HumanoidRootPart", 10)
            if not HRP then continue end
            task.wait(2)
            EquipToolByName(selectedFarmingTool)
            continue
        end

        -- SELECTIVE FARMING SECTION (Fixed robust loop)
        if isSelectiveFarming and #selectedMobs > 0 then
            local mob = FindSelectiveTargetMob(selectedMobs)
            if mob then
                FightMobLoop(mob, function() return isSelectiveFarming end)
            else
                task.wait(1)
            end
            continue
        end

        -- DO NOT TOUCH AUTO LEVEL FARM BELOW THIS LINE
        if not isRunning then continue end

        local statsFolder = LocalPlayer:FindFirstChild("Stats")
        local playerLevel = statsFolder and statsFolder:FindFirstChild("Level") and statsFolder.Level.Value or 0

        if playerLevel >= 100 then
            local tpNPC = GetTeleportNPC()
            if tpNPC then
                local tpPart = tpNPC:FindFirstChild("HumanoidRootPart") or tpNPC:FindFirstChild("Torso")
                if tpPart then
                    local distToTP = (HRP.Position - tpPart.Position).Magnitude
                    if distToTP < 1000 then
                        TweenTo(tpPart.CFrame * CFrame.new(0, 0, 3))
                        if not isRunning then break end
                        local tpPrompt = tpPart:FindFirstChild("ProximityPrompt") or tpNPC:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if tpPrompt then
                            fireproximityprompt(tpPrompt)
                            task.wait(5)
                            continue
                        end
                    end
                end
            end
        end

        local questFolder = LocalPlayer:FindFirstChild("QuestValue")
        local targetValue = questFolder and questFolder:FindFirstChild("Target")
        local targetName = targetValue and targetValue.Value

        local bestQuestMarker, bestStartLevel, bestQuestNPC = GetBestQuestInfo()
        if not bestQuestMarker and not bestQuestNPC then
            warn("[AutoFarmHub] No marker/NPC matched for current level")
        end

        if targetName ~= "" and targetName ~= nil then
            if bestStartLevel > lastPickedStartLevel then
                pcall(function()
                    local cancelRemote = ReplicatedStorage:FindFirstChild("Quest") and ReplicatedStorage.Quest:FindFirstChild("CancelQuest")
                    if cancelRemote then cancelRemote:FireServer() end
                end)
                task.wait(1)
                targetName = ""
            end
        end

        if targetName == "" or not targetName then
            local targetObj = bestQuestNPC or bestQuestMarker

            if targetObj then
                local targetPart = targetObj:FindFirstChild("HumanoidRootPart") or targetObj:FindFirstChild("Torso") or targetObj:FindFirstChildWhichIsA("BasePart", true)

                if targetPart then
                    local targetCFrame = targetPart.CFrame * CFrame.new(0, 0, 3)
                    local tweenSuccess = TweenTo(targetCFrame)
                    if not tweenSuccess then
                        warn("[AutoFarmHub] TweenTo failed reaching " .. targetObj.Name)
                    end
                    if not isRunning then break end

                    if tweenSuccess then
                        local attempts = 0
                        while isRunning and attempts < 15 do
                            local currentTarget = LocalPlayer:FindFirstChild("QuestValue") and LocalPlayer.QuestValue:FindFirstChild("Target")
                            if currentTarget and currentTarget.Value ~= "" then
                                lastPickedStartLevel = bestStartLevel
                                break
                            end

                            if targetPart and HRP then HRP.CFrame = targetPart.CFrame * CFrame.new(0, 0, 0) end

                            if bestQuestNPC then
                                local prompt = bestQuestNPC:FindFirstChildWhichIsA("ProximityPrompt", true)
                                if prompt and prompt.Enabled then
                                    fireproximityprompt(prompt)
                                end
                            end

                            task.wait(0.3)
                            attempts = attempts + 1
                        end
                    end
                else
                    warn("[AutoFarmHub] " .. targetObj.Name .. " has no HumanoidRootPart/Torso/BasePart")
                    task.wait(3)
                end
            else
                local areaNpcs = GetAllAreaTeleportNPCs()
                local teleportTarget = GetLevelMatchedAreaTeleportNPC(playerLevel, areaNpcs)
                local matchedByLevel = teleportTarget ~= nil

                if not teleportTarget and #areaNpcs > 0 then
                    if areaTeleportIndex > #areaNpcs then areaTeleportIndex = 1 end
                    teleportTarget = areaNpcs[areaTeleportIndex]
                end

                if teleportTarget then
                    local tpPart = teleportTarget:FindFirstChild("HumanoidRootPart") or teleportTarget:FindFirstChild("Torso") or teleportTarget:FindFirstChildWhichIsA("BasePart", true)
                    if tpPart then
                        warn("[AutoFarmHub] No quest target in this area, going to " .. teleportTarget.Name)
                        TweenTo(tpPart.CFrame * CFrame.new(0, 0, 3))
                        if not isRunning then break end
                        local prompt = tpPart:FindFirstChild("ProximityPrompt") or teleportTarget:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if prompt then
                            fireproximityprompt(prompt)
                            task.wait(5)
                            if not matchedByLevel then
                                areaTeleportIndex = areaTeleportIndex + 1
                            end
                        end
                    else
                        task.wait(3)
                    end
                else
                    warn("[AutoFarmHub] No targetObj available, idling")
                    task.wait(3)
                end
            end
        else
            local mob = FindTargetMob(targetName)
            if mob then
                FightMobLoop(mob, function() return isRunning end)
            else
                task.wait(1)
            end
        end
    end

    end)

    farmLoopActive = false

    if not ok then
        warn("[AutoFarmHub] AutoFarmLoop error: " .. tostring(err))
    end
end

--// Raid Farm Loop
local function FindAnyRaidMob()
    return FindMobByFilter(function(name) return true end)
end

local function RaidFarmLoop()
    if farmLoopActive then return end
    farmLoopActive = true

    local ok, err = pcall(function()

    while isRaidFarming do
        task.wait(0.5)
        if not isRaidFarming then break end

        local Character = LocalPlayer.Character
        local HRP = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")

        if not Character or not HRP or not Humanoid or Humanoid.Health <= 0 then
            Character = LocalPlayer.CharacterAdded:Wait()
            HRP = Character:WaitForChild("HumanoidRootPart", 10)
            if not HRP then continue end
            task.wait(2)
            EquipToolByName(selectedFarmingTool)
            continue
        end

        local mob = FindAnyRaidMob()
        if mob then
            FightMobLoop(mob, function() return isRaidFarming end)
        else
            task.wait(1)
        end
    end

    end)

    if not ok then
        warn("[AutoFarmHub] RaidFarmLoop error: " .. tostring(err))
    end

    farmLoopActive = false
end

